{
  "name": "@phfront/millennium-ui",
  "version": "0.1.20",
  "repository": {
    "type": "git",
    "url": "https://github.com/phfront/millennium-ui.git"
  },
  "publishConfig": {
    "@phfront:registry": "https://npm.pkg.github.com/"
  },
  "private": false,
  "description": "Design System do Ecossistema Millennium Nexus",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tailwind-preset": {
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs",
      "types": "./dist/tailwind-preset.d.ts"
    },
    "./styles": "./src/styles/globals.css",
    "./logo.svg": "./src/assets/logo.svg"
  },
  "files": [
    "dist",
    "src/styles",
    "src/assets"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/ensure-use-client.mjs",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4",
    "recharts": ">=2.12.0"
  },
  "dependencies": {
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "recharts": "^2.15.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
